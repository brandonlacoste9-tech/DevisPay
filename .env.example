# Production (Netlify): https://devispay.com
# Set these in Netlify → Site configuration → Environment variables
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string

# Stripe platform + Connect (each business gets their own Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional platform fee in basis points (250 = 2.5%). Default 0.
# STRIPE_PLATFORM_FEE_BPS=0

# Neon Postgres (required on Netlify for real data)
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
